ENV=dev
API_PORT=8080
API_HOST_PORT=8080
NGINX_HOST_PORT=8088

POSTGRES_DSN=postgres://app:app@postgres:5432/app?sslmode=disable
REDIS_ADDR=redis:6379
JOB_QUEUE_KEY=jobs
SUNO_CALLBACK_QUEUE_KEY=suno_callbacks
NOTIFIER_CHANNEL=job_updates

S3_ENDPOINT=minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET=tracks

SUNO_MODE=dev
SUNO_BASE_URL=https://api.sunoapi.org
SUNO_API_KEY=
# In dev this can stay internal for local/manual callback testing.
# In prod this must be a publicly reachable URL, for example:
# https://your-domain.example/suno/callback
SUNO_CALLBACK_URL=http://api:8080/internal/suno/callback
# Optional fallback for local real-Suno checks when callback URL is not public.
# Defaults to auto-enable in non-dev only when SUNO_CALLBACK_URL is internal.
SUNO_POLL_FALLBACK=
SUNO_POLL_INTERVAL=20s
SUNO_POLL_TIMEOUT=10m
SUNO_CALLBACK_SECRET=local-dev-token
